spring:
  datasource:
    url: "jdbc:postgresql://localhost:5432/resume"
    username: "postgres"
    password: ""
    driver-class-name: org.postgresql.Driver
  flyway:
    enabled: true
    locations: classpath:db/migration
  jpa:
    show-sql: false
    generate-ddl: false
    hibernate:
      ddl-auto: validate
    database: postgresql
server:
  port: 8080
api:
  resume:
    api-base-url: ""
    api-key-name: ""
    api-key: ""